# ═══════════════════════════════════════════════════════════════════════════
# ⚙️ CONFIGURAÇÃO DO PROJETO - Sistema de Sincronização Pluviométrica
# ═══════════════════════════════════════════════════════════════════════════
#
#   NIMBUS (alertadb) → Servidor 166 (alertadb_cor) → Google BigQuery
#
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# 🌧️ BANCO ORIGEM - NIMBUS (alertadb)
# ───────────────────────────────────────────────────────────────────────────
DB_ORIGEM_HOST=10.2.223.114
DB_ORIGEM_NAME=alertadb
DB_ORIGEM_USER=planejamento_cor
DB_ORIGEM_PASSWORD=secret_key
DB_ORIGEM_PORT=5432
DB_ORIGEM_SSLMODE=disable

# ───────────────────────────────────────────────────────────────────────────
# 🖥️ BANCO DESTINO - Servidor 166 (alertadb_cor)
# ───────────────────────────────────────────────────────────────────────────
DB_DESTINO_HOST=10.50.30.166
DB_DESTINO_NAME=alertadb_cor
DB_DESTINO_USER=postgres
DB_DESTINO_PASSWORD=secret_key
DB_DESTINO_PORT=5432

# ───────────────────────────────────────────────────────────────────────────
# ⏱️ CONFIGURAÇÕES DE SINCRONIZAÇÃO
# ───────────────────────────────────────────────────────────────────────────

# Intervalo de verificação (segundos) — padrão: 300 (5 minutos)
INTERVALO_VERIFICACAO=300

# ───────────────────────────────────────────────────────────────────────────
# 🌐 CONFIGURAÇÕES DA API REST (app.py)
# ───────────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG=False

# API Key (opcional — deixe vazio para acesso livre)
API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# 📊 GOOGLE BIGQUERY (opcional)
# ───────────────────────────────────────────────────────────────────────────
# Credenciais: credentials/credentials.json (service account)
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET_ID_NIMBUS=alertadb_cor_raw
BIGQUERY_DATASET_ID_SERVIDOR166=alertadb_166_raw
BIGQUERY_TABLE_ID=pluviometricos
BIGQUERY_TABLE_ID_METEOROLOGICOS=meteorologicos

# ═══════════════════════════════════════════════════════════════════════════
